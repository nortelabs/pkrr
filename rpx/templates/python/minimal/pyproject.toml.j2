[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ name }}"
version = "{{ version }}"
description = "{{ description | default('') }}"
readme = "README.md"
requires-python = ">=3.9"
license = { text = "{{ license }}" }
{% if authors %}
authors = [{% for a in authors %}{ name = "{{ a.name }}"{% if a.email %}, email = "{{ a.email }}"{% endif %} }{{ ", " if not loop.last }}{% endfor %}]
{% endif %}
keywords = {{ (keywords or []) | tojson }}
urls = { Homepage = "{{ homepage | default('') }}" }
dependencies = {{ (python.requires or []) | tojson }}

[tool.pytest.ini_options]
minversion = "7.0"
addopts = "-ra -q"
testpaths = ["tests"]

[tool.hatch.build.targets.wheel]
packages = ["src/{{ name }}"]

[tool.hatch.build.targets.sdist]
include = [
  "src/**",
  "README.md",
  "LICENSE",
  "pyproject.toml",
  "tests/**",
]
